{
  "manifest_version": 3,
  "name": "Apply2Board",
  "version": "1.1.0",
  "description": "Save job listings to a local Kanban board with AI cover letter generation.",
  "permissions": ["storage"],
  "host_permissions": [
    "<all_urls>",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Apply2Board"
  },
  "options_page": "settings/settings.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/constants.js",
        "lib/storage.js",
        "lib/attachments.js",
        "content/extractor.js",
        "content/content.js",
        "content/selection-toolbar.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "settings/settings.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
